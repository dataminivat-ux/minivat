# ============================================
# MINI VAT PREMIUM — Variáveis de ambiente
# Copie para .env.local e preencha
# ============================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...            # NUNCA expor; server only
SUPABASE_PROJECT_ID=xxxxxxxx                    # Pra gerar tipos

# ---------- App ----------
NEXT_PUBLIC_SITE_URL=https://www.minivatpremium.com.br
NEXT_PUBLIC_SITE_NAME=MINI VAT PREMIUM
NODE_ENV=development

# Admins (whitelist por email separado por vírgula)
ADMIN_EMAILS=vst2002@gmail.com,diego@sevynlabs.com

# ---------- Mercado Pago ----------
# Pega em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxx        # server only
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxxxx                            # verifica x-signature
MERCADOPAGO_SANDBOX=true                                          # false em produção

# ---------- Melhor Envio ----------
# Cria token em: melhorenvio.com.br → Configurações → API
MELHOR_ENVIO_TOKEN=Bearer eyJ0eXAiOi...                          # bearer completo
MELHOR_ENVIO_FROM_CEP=00000000                                    # CEP origem do Vinícius
MELHOR_ENVIO_SANDBOX=true
MELHOR_ENVIO_BASE_URL=https://sandbox.melhorenvio.com.br         # ou https://www.melhorenvio.com.br
MELHOR_ENVIO_USER_AGENT=MiniVatPremium contato@minivatpremium.com.br

# ---------- Resend ----------
# Cria key em: resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=contato@minivatpremium.com.br
RESEND_REPLY_TO=contato@minivatpremium.com.br

# ---------- Analytics ----------
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX                                    # único pixel que vai no código
# GA4 e Meta Pixel são configurados DENTRO do GTM, não aqui

# ---------- Sentry ----------
# Cria projeto em: sentry.io
SENTRY_DSN=https://xxxxxxxxxxxxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=sevyn-labs
SENTRY_PROJECT=minivat-ecommerce
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx

# ---------- Upstash Redis (rate limit) ----------
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxx

# ---------- Cloudflare (DNS/CDN — opcional via API se quiser purge programático) ----------
CLOUDFLARE_ZONE_ID=xxxxx
CLOUDFLARE_API_TOKEN=xxxxx

# ============================================
# FASE 2 — não preencher na Fase 1
# ============================================

# Bling ERP
BLING_API_KEY=
BLING_OAUTH_CLIENT_ID=
BLING_OAUTH_CLIENT_SECRET=

# WebmaniaBR NF-e
WEBMANIA_CONSUMER_KEY=
WEBMANIA_CONSUMER_SECRET=
WEBMANIA_ACCESS_TOKEN=
WEBMANIA_ACCESS_TOKEN_SECRET=

# Evolution API + n8n
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
N8N_WEBHOOK_URL=

# Stripe (internacional)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Meta CAPI (server-side)
META_CAPI_TOKEN=
META_PIXEL_ID=
